#!/bin/sh

# =============================================================================
# Pre-commit hook
# 1. lint-staged (ESLint + Prettier sur fichiers stages)
# 2. gitleaks (scan des secrets)
# =============================================================================

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# -----------------------------------------------------------------------------
# 1. LINT-STAGED (si disponible)
# -----------------------------------------------------------------------------
if command -v pnpm &> /dev/null && [ -f "package.json" ]; then
    # Verifier si lint-staged est configure
    if grep -q "lint-staged" package.json 2>/dev/null; then
        echo -e "${YELLOW}🔍 Running lint-staged...${NC}"
        pnpm lint-staged
        if [ $? -ne 0 ]; then
            echo -e "${RED}❌ lint-staged failed. Commit blocked.${NC}"
            exit 1
        fi
        echo -e "${GREEN}✅ lint-staged passed${NC}"
    fi
fi

# -----------------------------------------------------------------------------
# 2. GITLEAKS (scan secrets)
# -----------------------------------------------------------------------------
if command -v gitleaks &> /dev/null; then
    echo -e "${YELLOW}🔍 Scanning for secrets with gitleaks...${NC}"
    gitleaks protect --staged --no-banner --exit-code 1
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✅ No secrets detected${NC}"
    else
        echo ""
        echo -e "${RED}❌ Secrets detected! Commit blocked.${NC}"
        echo ""
        echo "Options:"
        echo "  1. Remove the secrets from your code"
        echo "  2. Add to .gitleaksignore if false positive"
        echo "  3. git commit --no-verify (not recommended)"
        exit 1
    fi
else
    echo -e "${YELLOW}⚠️  gitleaks not installed (brew install gitleaks)${NC}"
fi

exit 0
